<?xml version="1.0" encoding="utf-8"?>
<odoo>
	<record model="res.groups.privilege" id="res_groups_privilege_biometricdevice">
		<field name="name">Biometric Devices</field>
		<field name="sequence">100</field>
		<field name="category_id" ref="base.module_category_human_resources"/>
	</record>
    
	<record id="group_biometric_device_user" model="res.groups">
		<field name="name">Biometric User</field>
		<field name="privilege_id" ref="hr_attendance_zktecho.res_groups_privilege_biometricdevice" />
		<field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
	</record>
	
	<record id="group_biometric_device_manager" model="res.groups">
		<field name="name">Biometric Manager</field>
		<field name="privilege_id" ref="hr_attendance_zktecho.res_groups_privilege_biometricdevice" />
		<field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
		<field name="implied_ids" eval="[(4, ref('hr_attendance_zktecho.group_biometric_device_user'))]"/>
	</record>

</odoo>
