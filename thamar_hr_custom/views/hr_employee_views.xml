<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_inherit_hire_date" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.hire.date</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[@name='payroll_information']//label[@for='contract_date_start']" position="before">
                <field name="hire_date"/>
            </xpath>
            <xpath expr="//page[@name='work_information']//field[@name='parent_id']" position="after">
                <field name="admin_type"/>
            </xpath>
        </field>
    </record>
</odoo>
