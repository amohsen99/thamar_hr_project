<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ================================================================ -->
    <!-- Smart button on Employee form to show their loans                 -->
    <!-- ================================================================ -->
    <record id="hr_employee_view_form_inherit_loan" model="ir.ui.view">
        <field name="name">hr.employee.form.inherit.loan</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_open_loans"
                        type="object"
                        class="oe_stat_button"
                        icon="fa-money"
                        groups="hr_payroll.group_hr_payroll_user">
                    <field name="loan_count"
                           widget="statinfo"
                           string="Loans"/>
                </button>
            </xpath>
        </field>
    </record>

</odoo>
