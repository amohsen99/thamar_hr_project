<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- ============================================================ -->
        <!-- Sequence                                                      -->
        <!-- ============================================================ -->
        <record id="seq_hr_loan" model="ir.sequence">
            <field name="name">Employee Loan</field>
            <field name="code">hr.loan</field>
            <field name="prefix">LOAN/%(year)s/</field>
            <field name="padding">4</field>
            <field name="company_id" eval="False"/>
        </record>

        <!-- ============================================================ -->
        <!-- Payslip Input Type                                            -->
        <!-- ============================================================ -->
        <record id="input_loan_deduction" model="hr.payslip.input.type">
            <field name="name">Loan Deduction</field>
            <field name="code">LOAN_DED</field>
            <field name="country_id" eval="False"/>
        </record>

        <!-- ============================================================ -->
        <!-- Salary Rule — Loan Deduction (DED category)                   -->
        <!-- ============================================================ -->
        <record id="salary_rule_loan_deduction" model="hr.salary.rule">
            <field name="category_id" ref="hr_payroll.DED"/>
            <field name="name">Loan Deduction</field>
            <field name="sequence">150</field>
            <field name="code">LOAN_DED</field>
            <field name="condition_select">python</field>
            <field name="condition_python">result = 'LOAN_DED' in inputs</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = -inputs['LOAN_DED'].amount
            </field>
            <field name="struct_id" ref="hr_payroll.structure_002"/>
            <field name="appears_on_payslip" eval="True"/>
        </record>

    </data>
</odoo>
